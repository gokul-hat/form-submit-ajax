<h1>Books List</h1>
<div class="col-lg-12 mt-5 mb-5">
  <%= link_to 'New Book', new_path, class: 'btn btn-primary mb-3' %>
  <table class="table table-dark table-bordered">
    <thead>
      <tr>
        <th></th>
        <th>Name</th>
        <th>Price</th>
        <th>Author</th>
        <th>Genre</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td>
            <div class="form-check">
              <input type="checkbox"  id="book_<%= book.id%>" class="form-check-input book-select-check " data-book-id="<%= book.id %>">
              <label class="form-check-label" for="book_<%= book.id%>"></label>
            </div>
          </td>
          
          <td><%= book.title %></td>
          <td><%= book.price %></td>
          <td><%= book.author %></td>
          <td><%= book.genre %></td>
          <td>
            <%= link_to 'Show', show_path(book.id), class: 'btn btn-info' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <button type="button" class="btn btn-danger" id="delete-books" style="display:none">Delete Books</button>
</div>
